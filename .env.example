# LeadAI — 环境变量配置
# 复制此文件为 .env 并填写真实值

# ─── 服务器 ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://your-frontend.vercel.app

# ─── MongoDB ────────────────────────────────────────────────────
# 免费: https://cloud.mongodb.com → Create Free Cluster
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/leadai?retryWrites=true&w=majority

# ─── AI API Keys ────────────────────────────────────────────────
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── WhatsApp Business API ──────────────────────────────────────
# 申请流程: https://developers.facebook.com/docs/whatsapp/cloud-api
# 1. 创建 Meta Business Account
# 2. 创建 WhatsApp Business App
# 3. 获取 Phone Number ID 和 Token

WHATSAPP_TOKEN=EAABwzLixnjYBOxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=102345678901234
WHATSAPP_VERIFY_TOKEN=leadai_webhook_2025   # 自定义，Webhook 验证用

# ─── 通知设置 ────────────────────────────────────────────────────
# Hot Lead 时发送通知到此手机号（老板/销售主管）
# 格式: 国家码+手机号，不含空格或符号
NOTIFY_PHONE=60123456789
